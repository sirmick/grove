#!/usr/bin/env bash
# Launch an AI assistant interactively, seeded with grove system prompt (how to drive the CLI)
# plus this project prompt (editable on the Project page -> _grove/prompt.md).
set -euo pipefail

usage() {
  cat <<\USAGE
Usage: ai [--codex|--claude] [--yolo] [--no-maintain] [provider args...]

Launch an AI assistant interactively, seeded with grove + project context.
Defaults to --codex.

If present, _grove/ai.json in the current space provides provider defaults
such as Codex sandbox mode, approval policy, working root, and extra writable
directories. Explicit provider args passed to this command come after config
args, so they can override the space defaults.

--yolo maps to the provider's unsafe permission-bypass mode:
  codex  -> --dangerously-bypass-approvals-and-sandbox
  claude -> --dangerously-skip-permissions

When the interactive session exits, a brief non-interactive "upkeep" pass
continues the conversation to record what you asked (the Project page's
frequent-actions menu, in _grove/actions.md) and a self-evaluation lesson,
then commits them. Disable it with --no-maintain or GROVE_AI_MAINTAIN=0.
USAGE
}

provider="codex"
provider_flag=""
yolo=0
maintain="${GROVE_AI_MAINTAIN:-1}"
args=()

while (($#)); do
  case "$1" in
    --codex|--claude)
      if [[ -n "$provider_flag" ]]; then
        echo "ai: choose only one of --codex or --claude" >&2
        exit 2
      fi
      provider="${1#--}"
      provider_flag="$1"
      shift
      ;;
    --yolo)
      yolo=1
      shift
      ;;
    --no-maintain)
      maintain=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      args+=("$@")
      break
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

space="${GROVE_SPACE:-$PWD}"
config_file="${GROVE_AI_CONFIG:-$space/_grove/ai.json}"
config_args=()

if [[ -f "$config_file" ]]; then
  config_output="$(
    AI_PROVIDER="$provider" AI_CONFIG="$config_file" AI_SPACE="$space" node <<'NODE'
const fs = require('fs')
const os = require('os')
const path = require('path')

const provider = process.env.AI_PROVIDER
const configPath = process.env.AI_CONFIG
const space = process.env.AI_SPACE || process.cwd()

function readConfig() {
  try {
    return JSON.parse(fs.readFileSync(configPath, 'utf8'))
  } catch (error) {
    console.error(`ai: failed to read ${configPath}: ${error.message}`)
    process.exit(2)
  }
}

function objectOrEmpty(value) {
  return value && typeof value === 'object' && !Array.isArray(value) ? value : {}
}

function resolvePath(value) {
  if (typeof value !== 'string' || value.length === 0) return undefined
  if (value === '$GROVE_SPACE') return space
  if (value.startsWith('$GROVE_SPACE/')) return path.join(space, value.slice('$GROVE_SPACE/'.length))
  if (value === '~') return os.homedir()
  if (value.startsWith('~/')) return path.join(os.homedir(), value.slice(2))
  if (path.isAbsolute(value)) return value
  return path.resolve(space, value)
}

const raw = readConfig()
const config = objectOrEmpty(raw)
const common = objectOrEmpty(config.common)
const providerConfig = objectOrEmpty(config[provider])
const merged = { ...config, ...common, ...providerConfig }
delete merged.common
delete merged.codex
delete merged.claude

const args = []

if (provider === 'codex') {
  const cd = resolvePath(merged.cd ?? merged.cwd ?? '.')
  if (cd) args.push('-C', cd)
  if (merged.sandbox) args.push('--sandbox', String(merged.sandbox))
  const approvalPolicy = merged.approvalPolicy ?? merged.askForApproval
  if (approvalPolicy) args.push('--ask-for-approval', String(approvalPolicy))
  const extraDirs = [
    ...(Array.isArray(merged.addDirs) ? merged.addDirs : []),
    ...(Array.isArray(merged.trustedDirs) ? merged.trustedDirs : []),
    ...(Array.isArray(merged.writableDirs) ? merged.writableDirs : []),
  ]
  for (const dir of extraDirs) {
    const resolved = resolvePath(dir)
    if (resolved) args.push('--add-dir', resolved)
  }
}

if (Array.isArray(merged.args)) {
  for (const arg of merged.args) args.push(String(arg))
}

process.stdout.write(args.join('\n'))
NODE
  )" || exit 2
  if [[ -n "$config_output" ]]; then
    mapfile -t config_args <<<"$config_output"
  fi
fi

prompt="$(grove ai prompt)"

# End-of-session upkeep pass: once the interactive session exits, continue that same conversation
# non-interactively so the assistant can record what it was asked (the frequent-actions menu in
# _grove/actions.md) plus a self-evaluation lesson, then commit. It already carries the grove +
# project system prompt from the resumed session, so this nudge stays short. Best-effort: it runs
# headless (must apply edits + git-commit without a prompt), and any failure is swallowed so it can
# never change the exit status the user saw from their own session.
maintenance_prompt="Automatic end-of-session upkeep — work non-interactively, then stop:
1. For any recurring kind of request you handled this session, update the frequent-actions menu in
   _grove/actions.md: add a new \"## Title\" entry or bump its \"**Asked:** N×\" count.
2. Self-evaluate this session and append one short lesson to the lessons collection, refreshing
   lessons/summary.md (create the collection if it does not exist yet).
3. Commit these notes. If nothing is worth recording, change nothing and exit."

run_maintenance() {
  [[ "$maintain" == 0 ]] && return 0
  case "$provider" in
    codex)
      codex exec resume --last "$maintenance_prompt" </dev/null \
        || echo "ai: end-of-session upkeep pass skipped (codex exec resume failed)" >&2
      ;;
    claude)
      claude --continue --print --permission-mode bypassPermissions "$maintenance_prompt" </dev/null \
        || echo "ai: end-of-session upkeep pass skipped (claude --continue failed)" >&2
      ;;
  esac
}

case "$provider" in
  codex)
    if ! command -v codex >/dev/null 2>&1; then
      echo "codex CLI not found on PATH. Install Codex CLI, then run ai again." >&2
      exit 127
    fi
    if ((yolo)); then args=(--dangerously-bypass-approvals-and-sandbox "${args[@]}"); fi
    set +e
    codex "${config_args[@]}" "${args[@]}" "$prompt"
    code=$?
    set -e
    run_maintenance
    exit "$code"
    ;;
  claude)
    if ! command -v claude >/dev/null 2>&1; then
      echo "claude CLI not found on PATH. Install Claude Code, then run ai --claude again." >&2
      exit 127
    fi
    if ((yolo)); then args=(--dangerously-skip-permissions "${args[@]}"); fi
    set +e
    claude --append-system-prompt "$prompt" "${config_args[@]}" "${args[@]}"
    code=$?
    set -e
    run_maintenance
    exit "$code"
    ;;
esac
