{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@grove/core": ["packages/core/src/index.ts"],
      "@grove/core/*": ["packages/core/src/*"],
      "@grove/ingest": ["packages/ingest/src/index.ts"]
    }
  }
}
